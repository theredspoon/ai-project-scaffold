#!/bin/sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
cd "$repo_root"

if ! command -v vale >/dev/null 2>&1; then
  echo "Missing required command: vale" >&2
  exit 1
fi

if ! command -v markdownlint-cli2 >/dev/null 2>&1; then
  echo "Missing required command: markdownlint-cli2" >&2
  exit 1
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

[ -n "$staged_files" ] || exit 0

found_markdown=0

IFS='
'
for path in $staged_files; do
  case "$path" in
    *.md)
      [ -f "$path" ] || continue
      found_markdown=1
      vale "$path"
      markdownlint-cli2 "$path"
      ;;
  esac
done
unset IFS

[ "$found_markdown" -eq 1 ] || exit 0
